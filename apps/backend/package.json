{
  "name": "@ea/backend",
  "version": "0.0.0",
  "private": true,
  "description": "EA AUTOMATIC — API (NestJS 10). Fase 1A: auth/RBAC, schema do domínio, admin de cadastros.",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:clientes": "tsx src/db/seed-clientes.ts",
    "db:seed:regua": "tsx src/db/seed-regua.ts",
    "db:seed:regua-padrao": "tsx src/db/seed-regua-padrao.ts",
    "db:seed:kit": "tsx src/db/seed-kit.ts",
    "db:seed:catalogos": "tsx src/db/seed-catalogos.ts",
    "db:seed:regras": "tsx src/db/seed-regras.ts",
    "db:seed:clientes-atualizada": "tsx src/db/seed-clientes-atualizada.ts",
    "db:seed:entidades-soulan": "tsx src/db/seed-entidades-soulan.ts",
    "db:view:clinica": "tsx src/db/view-relatorio-clinica.ts"
  },
  "dependencies": {
    "@ea/shared-types": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.3.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^7.0.0",
    "drizzle-orm": "^0.38.3",
    "ioredis": "5.10.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.10",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
