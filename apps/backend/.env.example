# EA AUTOMATIC — backend. Copie para apps/backend/.env e ajuste. (.env é git-ignored)

# Banco (ea-db, isolado do CentraAtend — porta 5433)
DATABASE_URL=postgres://ea:troque-este-segredo@127.0.0.1:5433/ea_automatic

# JWT HS256 (use segredos longos e aleatórios em qualquer ambiente real)
JWT_ACCESS_SECRET=troque-access-secret
JWT_REFRESH_SECRET=troque-refresh-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# Cookie do refresh token
COOKIE_SECURE=false

# CORS / OriginGuard — origens permitidas (frontend local)
ALLOWED_ORIGINS=http://127.0.0.1:3010,http://localhost:3010

# Porta da API (namespace EA)
BACKEND_PORT=3011

# Seed do admin inicial (SEM senha hardcoded no código — vem daqui)
EA_ADMIN_NOME=Administrador EA
EA_ADMIN_EMAIL=admin@ea.local
EA_ADMIN_PASSWORD=troque-no-primeiro-acesso

# Pandapé (INT-1 / Fase 5)
# Token do diretor (insumo §A.9). VAZIO = integração pronta porém INERTE:
# o job/tick roda mas não chama o Pandapé (paridade conceitual com o fail-fast
# anti-mock do commit 82c986e, mas aqui é INÉRCIA, não erro de boot).
PANDAPE_API_TOKEN=
# Host plausível da API v3 do Pandapé; confirme com o diretor antes de produção.
PANDAPE_API_BASE_URL=https://api.pandape.com.br

# Clicksign (INT-4 / assinatura)
# CLICKSIGN_API_TOKEN é INSUMO DO DIRETOR (§A.9) e vive só na VM (apps/backend/.env,
# git-ignored) — NUNCA versionado. Sem token, a integração fica pronta porém INERTE:
# o cron (infra/install-clicksign-cron.sh) dispara o tick e o endpoint responde, mas
# nada é enviado/baixado da Clicksign. É INÉRCIA, não mock (paridade com o commit 82c986e).
# Auth: header `Authorization: <token>`, content-type application/vnd.api+json.
CLICKSIGN_API_TOKEN=
# Sandbox por padrão; em produção use https://app.clicksign.com/api/v3 (confirme com o diretor).
CLICKSIGN_API_BASE_URL=https://sandbox.clicksign.com/api/v3

# Redis (ea-redis, isolado do CentraAtend — porta 6380) — fila BullMQ + rate-limit
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
