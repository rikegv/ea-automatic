# EA AUTOMATIC — variáveis da infra local. Copie para infra/.env e ajuste.
# infra/.env é git-ignored (segredos via env, fail-fast no compose).

# Postgres
POSTGRES_USER=ea
POSTGRES_PASSWORD=troque-este-segredo
POSTGRES_DB=ea_automatic
POSTGRES_PORT=5433

# Redis
REDIS_PORT=6380

# ai-service (INT-3 / Fase 4) — serviço interno, sem porta pública.
GCP_PROJECT=ea-v2-automatic
VERTEX_AI_LOCATION=us-central1
# Staging efêmera (§A.6): bind-mount compartilhado host (backend) ↔ container (ea-ai).
STAGING_DIR=/tmp/ea-staging
# Token de defesa em profundidade (header X-Internal-Token) entre backend e ea-ai.
INTERNAL_TOKEN=__defina__
# URL que o backend (host, dev) usa p/ falar com o ai-service.
AI_SERVICE_URL=http://localhost:8000

# Google Drive (INT-2) — IDs de pasta OPCIONAIS. O mapa default de pastas
# vive no código do backend; preencha aqui só para sobrescrever por ambiente.
# DRIVE_ROOT_FOLDER_ID=
# DRIVE_PRONTUARIOS_FOLDER_ID=
# DRIVE_KITS_FOLDER_ID=

# Pandapé (INT-1 / Fase 5) — INSUMO DO DIRETOR (§A.9), entregue VAZIO.
# Ausência de PANDAPE_API_TOKEN = integração PRONTA porém INERTE: o cron
# (infra/install-pandape-cron.sh) dispara o tick e o endpoint responde, mas
# nada é puxado do Pandapé. É INÉRCIA (e não mock) — paridade conceitual com
# o fail-fast anti-mock do commit 82c986e, sem quebrar o boot.
# O token real é consumido pelo backend (apps/backend/.env). Lido aqui também
# porque o script de cron carrega INTERNAL_TOKEN/BACKEND_PORT deste arquivo.
PANDAPE_API_TOKEN=
# Porta da API do backend (host) que o cron chama em 127.0.0.1.
BACKEND_PORT=3011
